{
  "name": "dops-github-actions",
  "version": "1.0.0",
  "description": "Collection of custom actions used in DOPS projects.",
  "scripts": {
    "preinstall": "node -e \"if(!process.cwd().includes('.serverless'))import('./bin/check-package-manager.mjs')\"",
    "build": "ncc build actions/aws-param-to-env/index.js -o actions/aws-param-to-env/dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit": "pnpm audit --audit-level moderate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RepublicServicesRepository/dops-github-actions.git"
  },
