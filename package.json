  "dependencies": {
    "@actions/core": "^1.4.0",
    "aws-sdk": "^2.963.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "pnpm": ">=11.0.0 <12.0.0",
    "node": ">=24.0.0 <25.0.0",
