# Note: pnpm reads auth/registry settings from .npmrc, and most other pnpm
# configuration can also be set here (see https://pnpm.io/npmrc). By convention this
# migration centralizes behavioural/supply-chain settings in pnpm-workspace.yaml
# (some — overrides, allowBuilds, minimumReleaseAge — MUST live there) and keeps
# this file limited to auth/registry plus the npm-blocking options below.

# Block npm, yarn, and bun: prevents accidental non-pnpm installs from writing to disk.
# Works in conjunction with the preinstall guard in bin/check-package-manager.mjs.
#
# engine-strict=true causes npm to abort with EBADENGINE when pnpm's node_modules is
# NOT present (fresh checkout). When pnpm's node_modules IS already installed, npm 11
# (Node 24) crashes earlier in @npmcli/arborist's deduplication pass with:
#   "Cannot read properties of null (reading 'matches')"
# This is a known npm 11 bug with pnpm's symlink layout. Either way, npm cannot install
# anything — the crash is the block. See: engines in package.json ("0.0.0-use-pnpm-instead").
engine-strict=true
legacy-peer-deps=true
